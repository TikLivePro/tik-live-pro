# Service health-check URLs used by the status page API route.
# Dev: set to localhost (services run on host via Turborepo) — copy to .env.local
# Prod: set via docker-compose environment blocks (Docker internal DNS)
API_GATEWAY_URL=http://api-gateway:3000
AUTH_SERVICE_URL=http://auth:3001
USERS_SERVICE_URL=http://users:3002
LIVE_SESSION_SERVICE_URL=http://live-session:3003
BILLING_SERVICE_URL=http://billing:3004
INTEGRATIONS_SERVICE_URL=http://integrations:3005
COMMENTS_SERVICE_URL=http://comments:3006
NOTIFICATIONS_SERVICE_URL=http://notifications:3007
ANALYTICS_SERVICE_URL=http://analytics:3008
STREAM_ORCHESTRATOR_URL=http://stream-orchestrator:3009
MEDIAMTX_API_URL=http://mediamtx:9997
NATS_MONITORING_URL=http://nats:8222
