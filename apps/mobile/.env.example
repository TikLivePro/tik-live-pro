# TikLivePro Mobile - Environment Variables Example
# Copy this file to .env in the same directory: cp .env.example .env

# --- API Configuration ---
# For Android Emulator, use http://10.0.2.2:3000 to point to the API Gateway.
# For iOS Simulator or physical devices, use http://localhost:3000 or your local IP.
API_URL=http://10.0.2.2:3000

# --- OAuth Credentials ---
# These should match the credentials configured in the integrations-service and api-gateway / auth-services.

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id-here

# TikTok OAuth
TIKTOK_CLIENT_KEY=your-tiktok-client-key-here
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret-here
