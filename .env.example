# ==============================================================================
# TikLivePro — Root environment reference
#
# This file documents EVERY environment variable used across all services.
# It is NOT a single file you source — each service reads its own .env.
#
# Quick setup:
#   for svc in api-gateway auth users integrations live-session \
#               stream-orchestrator billing comments notifications analytics; do
#     cp services/$svc/.env.example services/$svc/.env
#   done
#   cp apps/web/.env.example apps/web/.env
#
# Then fill in the values below and copy them into each service's .env as needed.
# Variables marked [ALL] must be identical across every service.
# Variables marked [service-name] are only used by that service.
# ==============================================================================


# ==============================================================================
# SHARED — required by every service
# ==============================================================================

# Runtime environment
NODE_ENV=development                  # development | production | test

# Log verbosity
LOG_LEVEL=info                        # trace | debug | info | warn | error

# NATS JetStream URL [ALL]
# Local dev:  nats://localhost:4222
# Production: nats://nats:4222  (Docker service name)
NATS_URL=nats://localhost:4222

# JWT signing secret [ALL] — must be IDENTICAL across all services
# Generate: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-64-character-or-longer-string-in-production

# Distributed tracing headers [ALL]
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id


# ==============================================================================
# DATABASE — PostgreSQL connection strings
# One database per service; same Postgres host, different DB name.
# Local dev: the init.sql script creates all DBs on first `make infra-up`.
# Production: use Neon.tech managed Postgres (see docs/deploy-github-student.md).
# ==============================================================================

# [scripts] Base URL used by db-migrate.sh / db-generate.sh
# The script appends the database name automatically (e.g. .../tiklivepro_auth).
DB_BASE_URL=postgresql://postgres:password@localhost:5432

# Per-service DATABASE_URL values (copy into each service's .env)
# [api-gateway]  — no database
# [auth]
AUTH_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_auth
# [users]
USERS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_users
# [live-session]
SESSIONS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_sessions
# [billing]
BILLING_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_billing
# [integrations]
INTEGRATIONS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_integrations
# [comments]
COMMENTS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_comments
# [notifications]
NOTIFICATIONS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_notifications
# [analytics]
ANALYTICS_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_analytics
# [stream-orchestrator]
STREAM_DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_stream

# [api-gateway, comments, stream-orchestrator] Redis URL
# Local dev: redis://localhost:6379
# Production: Upstash TLS URL — rediss://default:TOKEN@HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379


# ==============================================================================
# SERVICE PORTS
# Only change these if you have local port conflicts.
# ==============================================================================

# [api-gateway]
PORT_GATEWAY=3000
# [auth]
PORT_AUTH=3001
# [users]
PORT_USERS=3002
# [live-session]
PORT_SESSION=3003
# [billing]
PORT_BILLING=3004
# [integrations]
PORT_INTEGRATIONS=3005
# [comments]
PORT_COMMENTS=3006
# [notifications]
PORT_NOTIFICATIONS=3007
# [analytics]
PORT_ANALYTICS=3008
# [stream-orchestrator]
PORT_STREAM=3009
# [web]
PORT_WEB=3010


# ==============================================================================
# API GATEWAY — internal upstream URLs
# In Docker Compose these use service names (http://auth:3001).
# In local dev they point to localhost.
# ==============================================================================

AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
SESSION_SERVICE_URL=http://localhost:3003
BILLING_SERVICE_URL=http://localhost:3004
INTEGRATION_SERVICE_URL=http://localhost:3005
COMMENTS_SERVICE_URL=http://localhost:3006
NOTIFICATIONS_SERVICE_URL=http://localhost:3007
ANALYTICS_SERVICE_URL=http://localhost:3008
STREAM_ORCHESTRATOR_URL=http://localhost:3009


# ==============================================================================
# JWT TOKEN SETTINGS [auth]
# ==============================================================================

JWT_ACCESS_EXPIRES_IN=15m    # short-lived access token TTL
JWT_REFRESH_EXPIRES_IN=30d   # long-lived refresh token TTL


# ==============================================================================
# SMTP — transactional email [auth]
# Sends a welcome email after successful registration.
# Leave SMTP_USER blank to disable email sending entirely — registrations
# still work, a warning is logged instead.
#
# Supported providers (SMTP_PROVIDER):
#   gmail    → smtp.gmail.com:587  (requires a Google App Password, NOT your
#              account password — see docs/deploy-github-student.md §7b)
#   sendgrid → smtp.sendgrid.net:587  (use API key as SMTP_PASS)
#   custom   → supply SMTP_HOST / SMTP_PORT / SMTP_SECURE manually
#
# Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com/apppasswords
#   3. Create a password for "Mail" → 16-character code
#   Free limit: 500 emails/day
# ==============================================================================

SMTP_PROVIDER=gmail              # gmail | sendgrid | custom
SMTP_USER=                       # leave blank to disable
SMTP_PASS=
SMTP_FROM=TikLive Pro <noreply@tiklivepro.me>

# Only required when SMTP_PROVIDER=custom:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false              # true = TLS on port 465, false = STARTTLS


# ==============================================================================
# INTER-SERVICE SECURITY [comments, integrations]
# Used to authenticate direct HTTP calls between services (not via the gateway).
# Generate: openssl rand -hex 32
# ==============================================================================

INTERNAL_API_KEY=change-me-to-a-random-32-character-or-longer-key-in-production


# ==============================================================================
# TIKTOK OAUTH [integrations, stream-orchestrator]
# Create an app at developers.tiktok.com → Manage apps
# Required scopes: user.info.basic, video.list, live.streaming
# ==============================================================================

TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here


# ==============================================================================
# FACEBOOK / META OAUTH [integrations, stream-orchestrator]
# Create an app at developers.facebook.com → My Apps
# Required products: Facebook Login, Live Video API
# Required permissions: pages_show_list, pages_read_engagement,
#                       pages_manage_posts, publish_video
# ==============================================================================

FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here


# ==============================================================================
# GOOGLE OAUTH [apps/web — NextAuth only]
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3010/api/auth/callback/google
# ==============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ==============================================================================
# INTEGRATIONS SERVICE [integrations]
# ==============================================================================

# Base URL used to build OAuth callback URLs sent to providers.
# Local dev:   http://localhost:3005
# Production:  https://api.tiklivepro.me
OAUTH_REDIRECT_BASE_URL=http://localhost:3005

# AES-256-GCM key used to encrypt stored OAuth tokens at rest.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-for-social-tokens-here


# ==============================================================================
# STRIPE [billing]
# Test keys start with sk_test_ and are safe to use in development.
# Never commit live keys (sk_live_…) — use GitHub Secrets in production.
# Dashboard: dashboard.stripe.com → Developers → API keys
# ==============================================================================

STRIPE_SECRET_KEY=sk_test_yourstripekeyhere

# Webhook signing secret — from Stripe Dashboard → Developers → Webhooks
# Local dev: use the Stripe CLI  →  stripe listen --forward-to localhost:3004/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_yourwebhooksecrethere

# Price ID of the Premium plan — Dashboard → Products → [plan] → Price ID
STRIPE_PREMIUM_PRICE_ID=price_yourpremiumpriceidhere


# ==============================================================================
# STREAM ORCHESTRATOR [stream-orchestrator]
# ==============================================================================

RTMP_INGEST_PORT=1935
RTMP_INGEST_HOST=0.0.0.0
INTEGRATIONS_SERVICE_URL=http://localhost:3005

# MediaMTX — platform-native HLS/WebRTC streaming relay
# RTMP URL is internal (ffmpeg worker → MediaMTX). HLS URL is public (browser → viewer).
# Local dev: MediaMTX runs as a Docker container started by `make infra-up`.
# Production: set MEDIAMTX_HLS_URL to your Caddy-fronted subdomain.
MEDIAMTX_RTMP_URL=rtmp://localhost:1936
MEDIAMTX_HLS_URL=http://localhost:8888
# Production only — credentials for the MediaMTX REST API (9997).
# Not used in dev (dev config accepts any user with no password).
MEDIAMTX_API_USER=admin
MEDIAMTX_API_PASS=change-me-use-a-strong-password


# ==============================================================================
# COMMENTS SERVICE [comments]
# ==============================================================================

# How often (ms) the service polls platform APIs for new comments.
COMMENT_POLL_INTERVAL_MS=2000


# ==============================================================================
# USERS SERVICE [users]
# ==============================================================================

# Base URL of the CDN that serves user-uploaded avatars.
CDN_BASE_URL=https://cdn.tiklivepro.pro


# ==============================================================================
# NEXT.JS WEB APP [apps/web]
# ==============================================================================

# NextAuth.js — required
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Public URLs consumed by the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_COMMENTS_WS_URL=http://localhost:3006

# Internal URL used by Next.js server-side routes to reach the auth service
AUTH_SERVICE_INTERNAL_URL=http://localhost:3001

# Giphy (optional — enables GIF picker in the comment input)
# Free key at developers.giphy.com → Create an App → API
NEXT_PUBLIC_GIPHY_API_KEY=


# ==============================================================================
# OBSERVABILITY (local dev — docker-compose.dev.yml)
# ==============================================================================

# OpenTelemetry collector endpoint (services push traces here)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Grafana admin credentials — http://localhost:3099  (dev default: admin/admin)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
