{
  "name": "tik-live-pro",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@tik-live-pro/web",
    "dev:status": "turbo run dev --filter=@tik-live-pro/status",
    "build:web": "turbo run build --filter=@tik-live-pro/web",
    "build:status": "turbo run build --filter=@tik-live-pro/status",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "bash scripts/db-generate.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:down": "docker compose -f docker-compose.dev.yml down -v"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "drizzle-orm": ">=0.45.2",
      "ws": ">=8.20.1",
      "postcss": ">=8.5.10",
      "@xmldom/xmldom": ">=0.8.13",
      "esbuild": ">=0.25.0",
      "fast-xml-parser": ">=5.7.0",
      "uuid": ">=11.1.1"
    }
  }
}
