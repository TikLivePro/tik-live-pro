{
  "name": "@tik-live-pro/auth-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@tik-live-pro/config": "workspace:*",
    "@tik-live-pro/domain": "workspace:*",
    "@tik-live-pro/events": "workspace:*",
    "@tik-live-pro/logger": "workspace:*",
    "@tik-live-pro/shared-types": "workspace:*",
    "@tik-live-pro/validation": "workspace:*",
    "@types/nodemailer": "^8.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "nats": "^2.28.0",
    "nodemailer": "^8.0.9",
    "pg": "^8.13.0",
    "zod": "^3.23.0",
    "@neondatabase/serverless": "^1.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "*"
  }
}
