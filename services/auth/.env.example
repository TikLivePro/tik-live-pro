NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_auth

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_SECRET=change-me-to-a-random-64-character-or-longer-string-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Correlation
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id

# SMTP — transactional email (welcome email on registration)
# Provider presets: gmail | sendgrid | custom
# Leave SMTP_USER blank to disable email sending entirely.
SMTP_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anjaniaina.toky14@gmail.com
SMTP_PASS=ysqq brww hrup ppnw
SMTP_FROM=TikLive Pro <noreply@tiklivepro.me>
# Only required when SMTP_PROVIDER=custom
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
