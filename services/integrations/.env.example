# Integrations Service - Environment Variables
NODE_ENV=development
PORT=3005
LOG_LEVEL=info

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_integrations

# NATS Event Broker
NATS_URL=nats://localhost:4222

# Security (Should match other services validating JWTs)
JWT_SECRET=change-me-to-a-random-64-character-or-longer-string-in-production

# Internal service-to-service authentication key (min 32 chars)
INTERNAL_API_KEY=change-me-to-a-random-32-character-or-longer-key-in-production

# OAuth Integration Credentials
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# OAuth Callback URL (Base URL of integrations service OAuth endpoint)
OAUTH_REDIRECT_BASE_URL=http://localhost:3005

# Frontend app URL — used to redirect users after OAuth completes
FRONTEND_URL=http://localhost:3010

# Token Encryption (AES-256-GCM requires a secure 32+ character key)
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-for-social-tokens-here

# Correlation Tracking
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id
