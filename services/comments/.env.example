# Comments Service - Environment Variables
NODE_ENV=development
PORT=3006
LOG_LEVEL=info

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_comments

# NATS Event Broker
NATS_URL=nats://localhost:4222

# JWT — must match the secret used by all other services
# Generate: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-64-character-or-longer-string-in-production

# Internal service-to-service authentication key (min 32 chars)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-random-32-character-or-longer-key-in-production

# Comment polling interval (milliseconds) — how often platform APIs are polled
COMMENT_POLL_INTERVAL_MS=2000

# Integrations service URL — used to retrieve OAuth tokens for platform adapters
# In Docker Compose: http://integrations:3005
INTEGRATIONS_SERVICE_URL=http://localhost:3005

# TikTok API credentials — required to poll TikTok live comments
# From developers.tiktok.com → Manage apps → App Key / App Secret
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# Facebook / Meta API credentials — required to poll Facebook live comments
# From developers.facebook.com → My Apps → App ID / App Secret
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Distributed tracing headers
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id
