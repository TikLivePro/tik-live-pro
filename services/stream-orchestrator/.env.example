# Stream Orchestrator Service - Environment Variables
NODE_ENV=development
PORT=3009
LOG_LEVEL=info

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_stream

# NATS Event Broker
NATS_URL=nats://localhost:4222

# RTMP ingest — OBS / streaming software connects here
RTMP_INGEST_HOST=0.0.0.0
RTMP_INGEST_PORT=1935

# MediaMTX — platform-native streaming relay (Go binary, started by docker-compose)
# MEDIAMTX_RTMP_URL:   internal RTMP URL — ffmpeg reads from here (browser WHIP stream lands here).
#   Local dev:  rtmp://localhost:1936   Docker / prod: rtmp://mediamtx:1936
# MEDIAMTX_HLS_URL:    public HLS base URL — browsers watch the stream here.
#   Local dev:  http://localhost:8888   Prod: https://hls.tiklivepro.me
# MEDIAMTX_WEBRTC_URL: public WebRTC base URL — browsers push WHIP here.
#   Local dev:  http://localhost:8889   Prod: https://webrtc.tiklivepro.me
# MEDIAMTX_API_URL:    internal REST API — stream-orchestrator polls for new paths.
#   Local dev:  http://localhost:9997   Docker / prod: http://mediamtx:9997
MEDIAMTX_RTMP_URL=rtmp://localhost:1936
MEDIAMTX_HLS_URL=http://localhost:8888
# MEDIAMTX_WEBRTC_URL is the public WHIP base URL returned to the broadcaster's browser
# via GET /sessions/:id/ingest (whipUrl field). Must be HTTPS in production.
MEDIAMTX_WEBRTC_URL=http://localhost:8889
MEDIAMTX_API_URL=http://localhost:9997

# Internal service URL — used to fetch OAuth tokens for platform adapters
# In Docker Compose: http://integrations:3005
INTEGRATIONS_SERVICE_URL=http://localhost:3005

# TikTok API credentials
# From developers.tiktok.com → Manage apps → App Key / App Secret
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Facebook / Meta API credentials
# From developers.facebook.com → My Apps → App ID / App Secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── yt-dlp (platform URL resolution) ───────────────────────────────────────────
# Set to "true" to run `yt-dlp -U` at container startup (Docker only).
# Useful when the image was built with an older YTDLP_VERSION and you want the
# container to self-update without rebuilding. Requires outbound internet access.
# For production, prefer rebuilding the image with a newer YTDLP_VERSION instead.
YTDLP_AUTO_UPDATE=false

# Distributed tracing headers
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id

# ── Recording upload ────────────────────────────────────────────────────────────
# Leave RECORDING_STORAGE_PROVIDER unset to disable recording upload entirely.
# MediaMTX writes .fmp4 segments to RECORDINGS_DIR; this service uploads them
# every 15 s and deletes the local copy after a successful upload.
#
# Local dev — MinIO (docker-compose.dev.yml, port 9000)
# Requires record: true in infra/mediamtx/mediamtx.yml to generate segments.
RECORDINGS_DIR=/tmp/tiklive-recordings
RECORDING_STORAGE_PROVIDER=minio
RECORDING_STORAGE_BUCKET=tiklivepro-recordings
RECORDING_STORAGE_REGION=us-east-1
RECORDING_STORAGE_ENDPOINT=http://localhost:9000
RECORDING_STORAGE_ACCESS_KEY_ID=minioadmin
RECORDING_STORAGE_SECRET_ACCESS_KEY=minioadmin
# RECORDING_STORAGE_CDN_URL=   # not needed for local dev

# Production — Cloudflare R2
# RECORDINGS_DIR=/recordings
# RECORDING_STORAGE_PROVIDER=r2
# RECORDING_STORAGE_BUCKET=tiklivepro-recordings
# RECORDING_STORAGE_REGION=auto
# RECORDING_STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# RECORDING_STORAGE_ACCESS_KEY_ID=<R2 Access Key ID>
# RECORDING_STORAGE_SECRET_ACCESS_KEY=<R2 Secret Access Key>
# RECORDING_STORAGE_CDN_URL=https://pub-<hash>.r2.dev   # or custom domain if DNS on Cloudflare

# Production — DigitalOcean Spaces
# RECORDINGS_DIR=/recordings
# RECORDING_STORAGE_PROVIDER=do-spaces
# RECORDING_STORAGE_BUCKET=tiklivepro-recordings
# RECORDING_STORAGE_REGION=fra1
# RECORDING_STORAGE_ENDPOINT=https://fra1.digitaloceanspaces.com
# RECORDING_STORAGE_ACCESS_KEY_ID=<Spaces Key>
# RECORDING_STORAGE_SECRET_ACCESS_KEY=<Spaces Secret>
# RECORDING_STORAGE_CDN_URL=https://tiklivepro-recordings.fra1.cdn.digitaloceanspaces.com
