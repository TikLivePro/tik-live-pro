# Stream Orchestrator Service - Environment Variables
NODE_ENV=development
PORT=3009
LOG_LEVEL=info

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklivepro_stream

# NATS Event Broker
NATS_URL=nats://localhost:4222

# RTMP ingest — OBS / streaming software connects here
RTMP_INGEST_HOST=0.0.0.0
RTMP_INGEST_PORT=1935

# MediaMTX — platform-native streaming relay (Go binary, started by docker-compose)
# MEDIAMTX_RTMP_URL:   internal RTMP URL — ffmpeg reads from here (browser WHIP stream lands here).
#   Local dev:  rtmp://localhost:1936   Docker / prod: rtmp://mediamtx:1936
# MEDIAMTX_HLS_URL:    public HLS base URL — browsers watch the stream here.
#   Local dev:  http://localhost:8888   Prod: https://hls.tiklivepro.me
# MEDIAMTX_WEBRTC_URL: public WebRTC base URL — browsers push WHIP here.
#   Local dev:  http://localhost:8889   Prod: https://webrtc.tiklivepro.me
# MEDIAMTX_API_URL:    internal REST API — stream-orchestrator polls for new paths.
#   Local dev:  http://localhost:9997   Docker / prod: http://mediamtx:9997
MEDIAMTX_RTMP_URL=rtmp://localhost:1936
MEDIAMTX_HLS_URL=http://localhost:8888
# MEDIAMTX_WEBRTC_URL is the public WHIP base URL returned to the broadcaster's browser
# via GET /sessions/:id/ingest (whipUrl field). Must be HTTPS in production.
MEDIAMTX_WEBRTC_URL=http://localhost:8889
MEDIAMTX_API_URL=http://localhost:9997

# Internal service URL — used to fetch OAuth tokens for platform adapters
# In Docker Compose: http://integrations:3005
INTEGRATIONS_SERVICE_URL=http://localhost:3005

# TikTok API credentials
# From developers.tiktok.com → Manage apps → App Key / App Secret
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Facebook / Meta API credentials
# From developers.facebook.com → My Apps → App ID / App Secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Distributed tracing headers
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id
