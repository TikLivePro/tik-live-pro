# Notifications Service - Environment Variables
NODE_ENV=development
PORT=3007
LOG_LEVEL=info

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/tiklive_notifications

# NATS Event Broker
NATS_URL=nats://localhost:4222

# Security (Should match other services validating JWTs)
JWT_SECRET=change-me-to-a-random-64-character-or-longer-string-in-production

# Correlation Tracking
CORRELATION_ID_HEADER=x-correlation-id
TRACE_ID_HEADER=x-trace-id
