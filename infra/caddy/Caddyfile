tiklivepro.me, www.tiklivepro.me {
    reverse_proxy localhost:3010
}

api.tiklivepro.me {
    # WebSocket connections from the comments socket.io client go directly
    # to the comments service — the API gateway's fetch() proxy does not
    # handle WebSocket upgrades.
    handle /socket.io/* {
        reverse_proxy localhost:3006
    }

    # Stream orchestrator is an internal service; expose it under a
    # /stream-orchestrator prefix so the browser can reach it without a
    # separate subdomain. The prefix is stripped before forwarding.
    handle /stream-orchestrator/* {
        uri strip_prefix /stream-orchestrator
        reverse_proxy localhost:3009
    }

    handle {
        reverse_proxy localhost:3000
    }
}

hls.tiklivepro.me {
    reverse_proxy localhost:8888
    # MediaMTX sets its own Access-Control-Allow-Origin (echoes the Origin
    # header). Delete it and replace with * so any origin can fetch HLS
    # segments — the delete must come first to avoid duplicate values.
    header {
        -Access-Control-Allow-Origin
        Access-Control-Allow-Origin  "*"
        Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
        Access-Control-Allow-Headers "Range"
    }
}

webrtc.tiklivepro.me {
    # CORS preflight (OPTIONS) — respond directly without forwarding to
    # MediaMTX. The WHIP POST uses Content-Type: application/sdp, which is
    # not CORS-safelisted, so the browser always sends a preflight first.
    # MediaMTX does not reliably respond 2xx to OPTIONS, so we handle it here.
    @cors_preflight method OPTIONS

    handle @cors_preflight {
        header Access-Control-Allow-Origin  "*"
        header Access-Control-Allow-Methods "GET, HEAD, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization"
        header Access-Control-Max-Age       "86400"
        respond "" 204
    }

    # Actual WHIP / WebRTC requests — proxy to MediaMTX but replace its
    # CORS header (which echoes the request Origin) with a single * value.
    handle {
        reverse_proxy localhost:8889
        header {
            -Access-Control-Allow-Origin
            Access-Control-Allow-Origin  "*"
        }
    }
}
