# ==============================================================================
# Dockerfile.web — Next.js 15 production image (standalone output)
#
# Requires next.config.ts to have:
#   output: 'standalone'
#   outputFileTracingRoot: path.join(__dirname, '../../')
#
# Build (from repo root):
#   docker build \
#     -f infra/docker/Dockerfile.web \
#     -t ghcr.io/tik-live-pro/web:latest \
#     .
# ==============================================================================

ARG NODE_VERSION=22
ARG PNPM_VERSION=9.15.0

# ── Stage 1: base ─────────────────────────────────────────────────────────────
FROM node:${NODE_VERSION}-alpine AS base
ARG PNPM_VERSION
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
RUN apk add --no-cache dumb-init

# ── Stage 2: install all dependencies ─────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

COPY packages/config/package.json       ./packages/config/
COPY packages/domain/package.json       ./packages/domain/
COPY packages/events/package.json       ./packages/events/
COPY packages/i18n/package.json         ./packages/i18n/
COPY packages/logger/package.json       ./packages/logger/
COPY packages/platform-adapters/package.json ./packages/platform-adapters/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/validation/package.json  ./packages/validation/
COPY apps/web/package.json             ./apps/web/

RUN pnpm install --frozen-lockfile --filter "@tik-live-pro/web..."

# ── Stage 3: build ────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN pnpm install --frozen-lockfile --filter "@tik-live-pro/web..." --prod=false

ENV NEXT_TELEMETRY_DISABLED=1

RUN pnpm --filter "@tik-live-pro/web" build

# ── Stage 4: runtime (minimal — standalone bundle only) ───────────────────────
FROM node:${NODE_VERSION}-alpine AS runtime

RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs \
 && apk add --no-cache dumb-init wget

WORKDIR /app

# Standalone bundle already contains a trimmed node_modules; copy the whole tree
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./

# Static assets and public dir are NOT included in standalone — copy separately
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public       ./apps/web/public

USER nextjs

EXPOSE 3010
ENV PORT=3010
ENV HOSTNAME=0.0.0.0
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

HEALTHCHECK --interval=15s --timeout=5s --start-period=40s --retries=3 \
  CMD wget -qO- http://localhost:3010/ || exit 1

ENTRYPOINT ["dumb-init", "--"]
# With outputFileTracingRoot set to the monorepo root, Next.js places server.js
# at apps/web/server.js inside the standalone bundle
CMD ["node", "apps/web/server.js"]
